# 复制为 .env（本地测试用，GitHub Actions 中改用 Secrets，见 README）

# Anthropic（AI 打分，必填）
ANTHROPIC_API_KEY=

# Adzuna（免费注册，https://developer.adzuna.com/ ）
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# USAJobs（可选，https://developer.usajobs.gov/ ）
USAJOBS_API_KEY=
USAJOBS_USER_AGENT_EMAIL=

# data.gov API key（可选，用于历史签证担保数据 sponsorship_data.py。
# 不填会用公共的 DEMO_KEY，对我们这种低频调用够用；想更稳可以自己申请一个免费 key，
# 见 https://api.data.gov/signup/ ）
DATA_GOV_API_KEY=

# 邮件发送 - Resend（推荐，https://resend.com/ ）
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=

# 邮件发送 - 备选方案 Gmail SMTP（不使用 Resend 时才需要，见 README）
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
